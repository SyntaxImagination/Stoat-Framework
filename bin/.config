{
    "environment": "",
    "environmentVariables": {},
    "baseUrl" : "http://localhost",
    "net": [{
            "http": true,
            "data" : { "port": 5000 }
        },
        {
            "https": false,
            "data" : {
                "port": 0,
                "ssl": {
                    "cert": "",
                    "key": ""
                }
            }
        },
        {
            "ws": false,
            "data" : { "port": 0 }
        },
        {
            "wss": false,
            "data" : { "port": 0 }
        }
    ],
    "folders": {
        "config": "System",
        "helpers": "Helpers",
        "model": "Models",
        "view": "Public",
        "controller": "Engine",
        "uploadDirectory" : "Uploads",
        "flatStorage" : "FlatFiles",
        "others" : "OtherFiles"
    },
    "app": {
        "api": {
            "allow": true,
            "versionPrefix": ["v1"]
        }
    },
    "request": {
        "cors": false,
        "checkOrigin": false,
        "maxBodyBytes": 1048576,
        "allowedMethods": [
            "GET",
            "POST",
            "OPTIONS",
            "PATCH",
            "DELETE"
        ],
        "allowedHeaders": [
            "Content-Type",
            "Authorization",
            "Accept"
        ]
    },
    "response": {
        "indexPage": "index.html",
        "notFoundPage": "index.html"
    },
    "db": [{
        "engine": "",
        "package": "",
        "file": "",
        "url": "",
        "port": 0,
        "user": "",
        "password": "",
        "name": "",
        "ref": ""
    }],
    "packages": [],
    "definitions": {
    }
}